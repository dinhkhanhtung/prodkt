rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasStoreAccess(storeId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == storeId;
    }

    // ==================== USERS ====================
    match /users/{userId} {
      // User can read/write their own data
      // Admin can read/write all
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Allow create during registration (only for new user)
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // ==================== STORES ====================
    match /stores/{storeId} {
      // Only owner or admin can access store
      allow read: if isAuthenticated() && (hasStoreAccess(storeId) || isAdmin());
      allow write: if isAuthenticated() && (hasStoreAccess(storeId) || isAdmin());
      
      // Subcollections inherit parent rules
      match /{document=**} {
        allow read: if isAuthenticated() && (hasStoreAccess(storeId) || isAdmin());
        allow write: if isAuthenticated() && (hasStoreAccess(storeId) || isAdmin());
      }
    }

    // ==================== PRODUCTS ====================
    match /stores/{storeId}/products/{productId} {
      allow read: if isAuthenticated() && hasStoreAccess(storeId);
      allow write: if isAuthenticated() && hasStoreAccess(storeId);
    }

    // ==================== CUSTOMERS ====================
    match /stores/{storeId}/customers/{customerId} {
      allow read: if isAuthenticated() && hasStoreAccess(storeId);
      allow write: if isAuthenticated() && hasStoreAccess(storeId);
    }

    // ==================== SUPPLIERS ====================
    match /stores/{storeId}/suppliers/{supplierId} {
      allow read: if isAuthenticated() && hasStoreAccess(storeId);
      allow write: if isAuthenticated() && hasStoreAccess(storeId);
    }

    // ==================== ORDERS ====================
    match /stores/{storeId}/orders/{orderId} {
      allow read: if isAuthenticated() && hasStoreAccess(storeId);
      allow write: if isAuthenticated() && hasStoreAccess(storeId);
    }

    // ==================== PAYMENTS ====================
    match /payments/{paymentId} {
      // User can create payments for themselves
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // User can read their own payments
      // Admin can read all payments
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Only admin can update (verify/reject)
      allow update: if isAdmin();
      
      // No delete allowed
      allow delete: if false;
    }

    // ==================== BANK ACCOUNTS ====================
    match /bankAccounts/{accountId} {
      // Anyone can read (to show payment options)
      allow read: if true;
      
      // Only admin can write
      allow write: if isAdmin();
    }

    // ==================== NOTIFICATIONS ====================
    match /notifications/{notificationId} {
      // User can read their own notifications
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Admin can write/create notifications
      allow write: if isAdmin();
      
      // User can update (mark as read) their own notifications
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt']);
    }

    // ==================== CONFIGS (Admin Only) ====================
    match /configs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== ANALYTICS (Admin Only) ====================
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
